# ─────────────────────────────────────────────────────────────────────────────
# cdp-mcp — Environment Configuration
#
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.
#
# Variable groups:
#   MCP_*          → MCP server behaviour (limits, retry, logging)
#   REGISTRY_*     → Registry backend selection and configuration
#   CM_*           → Single CM instance (EnvRegistry only)
#   IMPALA_*       → SQL backend for IcebergRegistry (original dvergari mode)
# ─────────────────────────────────────────────────────────────────────────────

# ── Registry Backend ──────────────────────────────────────────────────────────
# Choose: file | env | iceberg
REGISTRY_BACKEND=file

# Path to cm_instances.yaml (used only with REGISTRY_BACKEND=file)
REGISTRY_FILE_PATH=cm_instances.yaml


# ── Single CM instance (used only with REGISTRY_BACKEND=env) ─────────────────
# CM_HOST=cm.example.com
# CM_PORT=7183
# CM_USERNAME=admin
# CM_PASSWORD=changeme
# CM_ENVIRONMENT=default
# CM_USE_TLS=false
# CM_VERIFY_SSL=true
# CM_API_VERSION=v51


# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_LOG_LEVEL=INFO
MCP_MAX_LOG_LINES=5000
MCP_MAX_LOG_RANGE_HOURS=48
MCP_MAX_RETRIES=3
MCP_RETRY_WAIT_SECONDS=2.0
MCP_MAX_CONCURRENT_REQUESTS=10
MCP_REQUESTS_PER_MINUTE=60
MCP_DEFAULT_METRIC_POINTS=100


# ── SQL Backend / IcebergRegistry (REGISTRY_BACKEND=iceberg only) ─────────────
# IMPALA_BACKEND=impala
# IMPALA_DATABASE=cdp_registry
# IMPALA_TABLE=cloudera_managers
# IMPALA_HOST=impala-coordinator.example.com
# IMPALA_AUTH_MECHANISM=LDAP
# IMPALA_USERNAME=svc-mcp-agent
# IMPALA_PASSWORD=changeme
# IMPALA_USE_SSL=true
# IMPALA_TIMEOUT_SECONDS=30
# IMPALA_POOL_SIZE=3
# IMPALA_REFRESH_INTERVAL_SECS=300
